# Copy to .env and fill in. With no key set, the app runs in MOCK mode.
LLM_PROVIDER=openai          # openai | anthropic | mock
LLM_MODEL=gpt-4o             # chat/reasoning model
EMBED_MODEL=text-embedding-3-small

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

DATA_DIR=data
TOP_K=8
LEX_WEIGHT=0.6              # hybrid retrieval: lexical vs semantic weight (0..1)
MAX_CLARIFYING_QUESTIONS=3
API_URL=http://localhost:8000
